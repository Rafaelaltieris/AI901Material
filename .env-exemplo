# Endpoint e chave do projeto Microsoft Foundry (instrutor fornece)
PROJECT_ENDPOINT=(instrutor fornece)
PROJECT_API_KEY=(instrutor fornece)
MODEL_DEPLOYMENT_NAME=gpt-4.1-mini

AZURE_EXISTING_AGENT_ID=agente-teste:1
AZURE_EXISTING_AIPROJECT_ENDPOINT=<ENDPOINT>

# Recursos específicos por serviço (instrutor fornece quando aplicável)
AZURE_LANGUAGE_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
AZURE_LANGUAGE_KEY=<chave>

AZURE_SPEECH_KEY=<chave>
AZURE_SPEECH_REGION=eastus

AZURE_VISION_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
AZURE_VISION_KEY=<chave>

AZURE_CU_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
AZURE_CU_KEY=<chave>